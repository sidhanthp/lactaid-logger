generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Meal {
  id                   String    @id @default(uuid())
  createdAt            DateTime  @default(now())
  food                 String
  dairyLevel           String
  estimatedLactoseGrams Float
  lactaidPills         Int
  symptoms             String?
  symptomNotes         String    @default("")

  @@map("meals")
}
